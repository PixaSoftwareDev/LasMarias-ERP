{
  "name": "@lasmarias/shared-schemas",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "echo 'no lint'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@lasmarias/tsconfig": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
