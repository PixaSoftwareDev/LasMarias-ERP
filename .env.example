# ===========================================
# Lácteos Las Marías — variables de entorno
# ===========================================
# Copiá este archivo a .env y completá los valores reales.
# NO commitees .env al repositorio.

# --- Postgres (dev local vía docker-compose) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lasmarias
POSTGRES_USER=lasmarias
POSTGRES_PASSWORD=lasmarias_dev

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# --- JWT ---
JWT_ACCESS_SECRET=cambiar-en-prod-secreto-de-acceso
JWT_REFRESH_SECRET=cambiar-en-prod-secreto-de-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
